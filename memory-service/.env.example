# Copy to .env and fill in. NEVER commit real values; inject these from your cloud's
# secret manager (AWS Secrets Manager / GCP Secret Manager / Azure Key Vault).

# Managed Redis Agent Memory (Iris), from the Redis Cloud console:
#   1. Create a database on Redis Cloud
#   2. Create an Agent Memory service for it
#   3. Copy the host, store id, and API key below
# Get this access through your approved company channels (not a personal account).
IRIS_HOST=https://<your-store>.agent-memory.redis.cloud
IRIS_STORE_ID=<store id>
IRIS_API_KEY=<bearer api key>

MEMORY_NAMESPACE=glasse-prod
